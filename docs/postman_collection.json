{
  "info": {
    "name": "SerpantSupply API",
    "description": "Complete REST API collection for SerpantSupply marketplace",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:8000" },
    { "key": "access_token", "value": "" },
    { "key": "refresh_token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/register/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"username\": \"testuser\", \"email\": \"test@example.com\", \"password\": \"SecurePass123\", \"password2\": \"SecurePass123\"}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "pm.test('Has access token', () => pm.expect(pm.response.json()).to.have.property('access'));",
              "pm.environment.set('access_token', pm.response.json().access);",
              "pm.environment.set('refresh_token', pm.response.json().refresh);"
            ]}
          }]
        },
        {
          "name": "Login (Get JWT)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/login/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"username\": \"testuser\", \"password\": \"SecurePass123\"}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.environment.set('access_token', pm.response.json().access);",
              "pm.environment.set('refresh_token', pm.response.json().refresh);"
            ]}
          }]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/refresh/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"refresh\": \"{{refresh_token}}\"}" }
          }
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/auth/me/",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          },
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] }
          }]
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "List Products",
          "request": { "method": "GET", "url": "{{base_url}}/api/products/" },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Returns array', () => pm.expect(pm.response.json()).to.be.an('array'));"
            ]}
          }]
        },
        {
          "name": "Search Products",
          "request": { "method": "GET", "url": "{{base_url}}/api/products/?q=snake&condition=New&sort=-price" }
        },
        {
          "name": "Get Product Detail",
          "request": { "method": "GET", "url": "{{base_url}}/api/products/1/" }
        },
        {
          "name": "Create Listing",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/products/create/",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"Ball Python\", \"price\": \"150.00\", \"description\": \"Healthy 2yr old ball python\", \"condition\": \"Used\"}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.test('Status 201', () => pm.response.to.have.status(201));"] }
          }]
        },
        {
          "name": "Update Listing",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/api/products/1/manage/",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"price\": \"125.00\"}" }
          }
        },
        {
          "name": "Delete Listing",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/products/1/manage/",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          },
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.test('Status 204', () => pm.response.to.have.status(204));"] }
          }]
        }
      ]
    },
    {
      "name": "My Account",
      "item": [
        {
          "name": "My Listings",
          "request": {
            "method": "GET", "url": "{{base_url}}/api/my/listings/",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        },
        {
          "name": "My Purchases",
          "request": {
            "method": "GET", "url": "{{base_url}}/api/my/purchases/",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        }
      ]
    },
    {
      "name": "Payments (PayPal)",
      "item": [
        {
          "name": "Create PayPal Order",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/payments/create-order/",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"product_id\": 1}" }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Has approve_url', () => pm.expect(pm.response.json()).to.have.property('approve_url'));"
            ]}
          }]
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Dashboard Stats",
          "request": {
            "method": "GET", "url": "{{base_url}}/api/admin/stats/",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        },
        {
          "name": "List All Users",
          "request": {
            "method": "GET", "url": "{{base_url}}/api/admin/users/",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        }
      ]
    }
  ]
}
